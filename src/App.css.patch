.telegram-card {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 1rem;
  border-radius: 14px;
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.1);
}
.telegram-left {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  flex: 1;
  min-width: 0;
  overflow: hidden;
}
.telegram-left .compensation-text {
  min-width: 0;
  overflow: hidden;
}
.telegram-left .compensation-text h3,
.telegram-left .compensation-text p {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.telegram-btn {
  background: linear-gradient(135deg, #2563eb, #1d4ed8);
  color: #fff;
  padding: 0.55rem 0.9rem;
  border-radius: 10px;
  font-size: 0.8rem;
  font-weight: 700;
  white-space: nowrap;
  flex-shrink: 0;
}
